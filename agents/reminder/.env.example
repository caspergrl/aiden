# Anthropic API — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Resend API — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Path to your Firebase Admin service account JSON
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Twilio (for text message reminders) — https://console.twilio.com/
# Leave blank to disable SMS sending
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Set to "true" to preview without sending anything
DRY_RUN=false
