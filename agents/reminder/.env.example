# Aiden Reminder Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Anthropic Claude API — rotate at console.anthropic.com if exposed
ANTHROPIC_API_KEY=sk-ant-...

# Resend email delivery — rotate at resend.com if exposed
RESEND_API_KEY=re_...

# Twilio SMS (optional — omit if not using SMS reminders)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Set to "true" to preview emails without sending
DRY_RUN=false
