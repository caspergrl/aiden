rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their own document and ALL subcollections beneath it.
    // SECURITY: role and status fields may ONLY be written via the Admin SDK
    // (Firebase Console or a trusted Cloud Function) — never by the client.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow creating the user doc, but client cannot set role or status
      allow create: if request.auth != null
                   && request.auth.uid == userId
                   && !request.resource.data.keys().hasAny(['role', 'status']);

      // Allow updating the user doc, but client cannot change role or status
      allow update: if request.auth != null
                   && request.auth.uid == userId
                   && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'status']);

      // Subcollections (appointments, recipients, medications, etc.) are
      // fully owned by the authenticated user
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

  }
}
